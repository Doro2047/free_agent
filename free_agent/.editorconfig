# EditorConfig is awesome: https://EditorConfig.org

root = true

[*]
charset = utf-8
end_of_line = lf
indent_style = space
indent_size = 2
insert_final_newline = true
trim_trailing_whitespace = true
max_line_length = 120

[*.md]
trim_trailing_whitespace = false
max_line_length = off

[*.{yml,yaml}]
indent_size = 2

[*.{json,jsonc}]
indent_size = 2

[*.toml]
indent_size = 2

[*.rs]
indent_size = 4
max_line_length = 100

[*.{sh,bash}]
indent_size = 4

[Makefile]
indent_style = tab

[Dockerfile*]
indent_size = 4

[*.proto]
indent_size = 2
